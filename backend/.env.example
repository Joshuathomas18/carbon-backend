# Database Configuration
# For development: Use SQLite with the shim (no cloud dependency)
# DATABASE_URL=sqlite:///./carbon.db
#
# For production: Use PostgreSQL
DATABASE_URL=sqlite:///./carbon.db

# Supabase (Optional, for real deployment)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# App Environment
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Twilio WhatsApp Integration
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=whatsapp:+1234567890

# Frontend URL (for magic link generation)
FRONTEND_URL=http://localhost:3000

# Google Earth Engine
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# Sarvam AI
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_BASE_URL=https://api.sarvam.ai

# Security (Change in production!)
SECRET_KEY=dev-secret-key-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Carbon Value
CARBON_VALUE_INR_PER_TONNE=40
